        "id": "sys_linksnitch",
        "kind": "software-system",
        "title": "LinkSnitch (Android)",
        "summary": "Single-package HCI research app (`com.research.hci.linksnitch`) that extracts URLs from focused or shared text, scores them with heuristics, and speaks short warnings via TTS.",
        "containerOverview": "Jetpack Compose launcher (`MainActivity` / `MainScreen`), `ShareActivity` for ACTION_SEND, `LinkSnitchAccessibilityService` for TYPE_VIEW_ACCESSIBILITY_FOCUSED, `TtsService` + `TtsManager` for speech, and Kotlin objects `UrlDetector`, `UrlAnalyzer`, `ExplanationGenerator` for analysis."
      },
      "ext_host_apps": {
        "id": "ext_host_apps",
        "kind": "external",
        "title": "Host apps (browser, email, …)",
        "summary": "Third-party apps that provide plain text via Android Share or expose link text in the accessibility tree."
      },
      "ext_android_platform": {
        "id": "ext_android_platform",
        "kind": "external",
        "title": "Android OS",
        "summary": "Delivers accessibility focus events; provides `TextToSpeech`, audio focus, and `Settings` for enabling the accessibility service."
      }
